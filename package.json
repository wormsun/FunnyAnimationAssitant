{
  "name": "funny-animation-assistant-web",
  "version": "0.1.0",
  "description": "Local-first community edition of a web animation creation tool for short-form animated stories.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && eslint src --cache && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tts:provider": "node examples/tts-provider/server.mjs",
    "dev:with-tts": "node examples/tts-provider/dev-with-tts.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --cache",
    "lint:fix": "eslint src --fix",
    "prepare": "husky",
    "betterer": "betterer",
    "betterer:ci": "betterer ci",
    "betterer:precommit": "betterer precommit",
    "fonts:build": "node scripts/build-fonts.js",
    "release:audit": "node tools/public-release-audit.mjs"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^0.5.2",
    "pinia": "^2.3.0",
    "pixi-filters": "^5.3.0",
    "pixi.js": "^7.3.2",
    "tone": "^14.7.77",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@betterer/betterer": "^6.0.0-alpha.1",
    "@betterer/cli": "^6.0.0-alpha.1",
    "@betterer/eslint": "^6.0.0-alpha.1",
    "@betterer/typescript": "^6.0.0-alpha.1",
    "@eslint/js": "^9.18.0",
    "@konghayao/cn-font-split": "^4.15.0",
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "happy-dom": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "sass": "^1.83.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
